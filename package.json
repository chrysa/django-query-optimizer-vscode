{
  "activationEvents": [
    "workspaceContains:**/*.sarif"
  ],
  "categories": [
    "Linters",
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "djangoQueryOptimizer.reload",
        "title": "Django Query Optimizer: Reload SARIF files"
      },
      {
        "command": "djangoQueryOptimizer.clear",
        "title": "Django Query Optimizer: Clear all diagnostics"
      }
    ],
    "configuration": {
      "properties": {
        "djangoQueryOptimizer.enabled": {
          "default": true,
          "description": "Enable/disable the Django Query Optimizer extension.",
          "type": "boolean"
        },
        "djangoQueryOptimizer.sarifPattern": {
          "default": "**/*.sarif",
          "description": "Glob pattern for SARIF files to watch (relative to workspace root).",
          "type": "string"
        }
      },
      "title": "Django Query Optimizer"
    }
  },
  "description": "Displays ORM optimization findings from django-query-optimizer SARIF reports as VS Code diagnostics.",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "c8": "^10.1.3",
    "eslint": "^10.3.0",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  },
  "displayName": "Django Query Optimizer",
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "media/icon.png",
  "keywords": [
    "django",
    "orm",
    "query",
    "n+1",
    "performance",
    "sarif"
  ],
  "license": "MIT",
  "main": "./out/src/extension.js",
  "name": "django-query-optimizer",
  "publisher": "chrysa",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrysa/django-query-optimizer-vscode"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "coverage": "vscode-test --coverage --coverage-reporter=lcovonly --coverage-reporter=text",
    "lint": "eslint src",
    "package": "vsce package",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./"
  },
  "version": "0.1.0"
}
