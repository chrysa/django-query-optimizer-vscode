{
  "name": "django-query-optimizer",
  "displayName": "Django Query Optimizer",
  "description": "Displays ORM optimization findings from django-query-optimizer SARIF reports as VS Code diagnostics.",
  "version": "0.1.0",
  "publisher": "chrysa",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Linters", "Other"],
  "keywords": ["django", "orm", "query", "n+1", "performance", "sarif"],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrysa/django-query-optimizer-vscode"
  },
  "license": "MIT",
  "activationEvents": ["workspaceContains:**/*.sarif"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Django Query Optimizer",
      "properties": {
        "djangoQueryOptimizer.sarifPattern": {
          "type": "string",
          "default": "**/*.sarif",
          "description": "Glob pattern for SARIF files to watch (relative to workspace root)."
        },
        "djangoQueryOptimizer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Django Query Optimizer extension."
        }
      }
    },
    "commands": [
      {
        "command": "djangoQueryOptimizer.reload",
        "title": "Django Query Optimizer: Reload SARIF files"
      },
      {
        "command": "djangoQueryOptimizer.clear",
        "title": "Django Query Optimizer: Clear all diagnostics"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.5.0"
  }
}
